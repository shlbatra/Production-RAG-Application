# .env
OPENAI_API_KEY=sk-your-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your-key-here
LANGCHAIN_PROJECT=prod-rag
APP_ENV=development
LOG_LEVEL=INFO
RATE_LIMIT=20/minute
CACHE_TTL_SECONDS=300
MAX_RETRIES=3

# Supabase (required for RAG features)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key
SUPABASE_DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# RAG Configuration (optional, these are defaults)
EMBEDDING_MODEL=text-embedding-3-small
RAG_RETRIEVAL_STRATEGY=hybrid   # similarity | bm25 | hybrid
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
MAX_UPLOAD_SIZE_MB=10

# GCP / Cloud Run
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GITHUB_REPO=owner/repo